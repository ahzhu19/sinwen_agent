LLM_MODEL_ID="your-model-id"
LLM_API_KEY="your-api-key"
LLM_BASE_URL="https://api.openai.com/v1"

# Optional search tool keys
TAVILY_API_KEY=""
SERPAPI_API_KEY=""

# PostgreSQL local Docker configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=hello_agents
POSTGRES_USER=hello_agents
POSTGRES_PASSWORD=hello-agents-password
DATABASE_URL=postgresql://hello_agents:hello-agents-password@localhost:55432/hello_agents

# Neo4j local Docker configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=hello-agents-password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=60

# Milvus local Docker configuration
MILVUS_URI=http://localhost:19530
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=hello_agents_vectors
MILVUS_EPISODIC_COLLECTION=hello_agents_episodic_vectors
MILVUS_SEMANTIC_COLLECTION=hello_agents_semantic_vectors
MILVUS_PERCEPTUAL_TEXT_COLLECTION=hello_agents_perceptual_text_vectors
MILVUS_PERCEPTUAL_IMAGE_COLLECTION=hello_agents_perceptual_image_vectors
MILVUS_PERCEPTUAL_AUDIO_COLLECTION=hello_agents_perceptual_audio_vectors
MILVUS_PERCEPTUAL_VIDEO_COLLECTION=hello_agents_perceptual_video_vectors
MILVUS_PERCEPTUAL_FILE_COLLECTION=hello_agents_perceptual_file_vectors
MILVUS_VECTOR_SIZE=1024
MILVUS_METRIC_TYPE=COSINE
MILVUS_TIMEOUT=30

# Milvus object storage console
MINIO_ENDPOINT=http://localhost:9000
MINIO_CONSOLE=http://localhost:9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Episodic memory recency window (seconds) for retrieval scoring
EPISODIC_MEMORY_RECENCY_SECONDS=2592000

# Embedding configuration
EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME="text-embedding-v3"
EMBED_API_KEY="your-embedding-api-key"
EMBED_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
